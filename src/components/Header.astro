---
interface Props {
  currentPage?: string;
}

const { currentPage = 'home' } = Astro.props;
const menuItems = [
  { label: 'Главная', href: '/', id: 'home' },
  { label: 'Меню', href: '/menu/', id: 'menu' },
  { label: 'Услуги', href: '/services/', id: 'services' },
  { label: 'Кейсы', href: '/cases/', id: 'cases' },
  { label: 'Блог', href: '/blog/', id: 'blog' },
  { label: 'Контакты', href: '/contact/', id: 'contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-dark-bg/95 backdrop-blur border-b border-dark-border">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16 md:h-20">
      {/* Logo */}
      <div class="flex items-center gap-2">
        <div class="text-gold text-2xl md:text-3xl font-serif font-bold">◆</div>
        <div class="hidden sm:block">
          <div class="text-white font-serif text-lg font-bold">Diamond</div>
          <div class="text-gold text-xs tracking-widest">PRO BAR</div>
        </div>
      </div>

      {/* Desktop Menu */}
      <div class="hidden lg:flex gap-8">
        {menuItems.map((item) => (
          <a
            href={item.href}
            class={`text-sm uppercase tracking-wide transition-colors ${
              currentPage === item.id
                ? 'text-gold border-b-2 border-gold'
                : 'text-gray-300 hover:text-gold'
            }`}
          >
            {item.label}
          </a>
        ))}
      </div>

      {/* CTA Button */}
      <div class="flex items-center gap-2 sm:gap-4">
        <a
          href="https://wa.me/79999999999"
          target="_blank"
          class="hidden sm:inline-block px-4 py-2 bg-gradient-gold text-dark-bg font-bold text-xs sm:text-sm rounded hover:shadow-lg hover:shadow-gold/50 transition-all"
        >
          WhatsApp
        </a>

        {/* Mobile Menu Button */}
        <button
          id="mobile-menu-btn"
          class="lg:hidden text-gold text-2xl"
          aria-label="Toggle menu"
        >
          ☰
        </button>
      </div>
    </div>

    {/* Mobile Menu */}
    <div
      id="mobile-menu"
      class="hidden lg:hidden pb-4 border-t border-dark-border"
    >
      {menuItems.map((item) => (
        <a
          href={item.href}
          class="block py-2 text-sm uppercase tracking-wide text-gray-300 hover:text-gold transition-colors"
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Close menu when link clicked
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>
