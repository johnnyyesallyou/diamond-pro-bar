---
interface Props {
  title: string;
  description: string;
  price: string;
  minOrder?: string;
  image?: string;
  features?: string[];
}

const { title, description, price, minOrder = '5 человек', image = 'https://images.unsplash.com/photo-1608439773649-abc10fbb03e0?w=500&h=500&fit=crop', features = [] } = Astro.props;
---

<div class="group cursor-pointer">
  <div class="relative overflow-hidden rounded-lg mb-4 h-64 sm:h-72">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-dark-bg/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end">
      <div class="p-4 sm:p-6 w-full">
        <a
          href="https://wa.me/79999999999"
          target="_blank"
          class="block w-full py-2 bg-gradient-gold text-dark-bg text-center font-bold rounded text-sm hover:shadow-lg hover:shadow-gold/50 transition-all"
        >
          Заказать
        </a>
      </div>
    </div>
  </div>

  <h3 class="text-xl sm:text-2xl font-serif font-bold text-white mb-2">{title}</h3>

  <p class="text-gray-400 text-sm sm:text-base mb-4 line-clamp-2">{description}</p>

  {features.length > 0 && (
    <ul class="space-y-2 mb-4 text-gray-400 text-sm hidden sm:block">
      {features.slice(0, 3).map((feature) => (
        <li class="flex items-center gap-2">
          <span class="text-gold">✓</span>
          <span>{feature}</span>
        </li>
      ))}
    </ul>
  )}

  <div class="flex justify-between items-end">
    <div>
      <p class="text-gold font-serif text-2xl sm:text-3xl font-bold">{price}</p>
      <p class="text-gray-500 text-xs sm:text-sm">{minOrder}</p>
    </div>
  </div>
</div>
