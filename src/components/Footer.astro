<footer class="bg-dark-bg border-t border-dark-border mt-16 sm:mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 sm:gap-12 mb-8 sm:mb-12">
      {/* Brand */}
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <div class="text-gold text-3xl font-serif">◆</div>
          <div>
            <div class="text-white font-serif text-xl font-bold">Diamond</div>
            <div class="text-gold text-xs tracking-widest">PRO BAR</div>
          </div>
        </div>
        <p class="text-gray-400 text-sm">
          Выездной бар под ключ в Москве и Московской области. Профессиональные барменты и коктейли для вашего события.
        </p>
      </div>

      {/* Navigation */}
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-widest mb-4">
          Меню
        </h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-gray-400 hover:text-gold text-sm transition-colors">Главная</a></li>
          <li><a href="/menu/" class="text-gray-400 hover:text-gold text-sm transition-colors">Меню</a></li>
          <li><a href="/services/" class="text-gray-400 hover:text-gold text-sm transition-colors">Услуги</a></li>
          <li><a href="/cases/" class="text-gray-400 hover:text-gold text-sm transition-colors">Кейсы</a></li>
        </ul>
      </div>

      {/* Contacts */}
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-widest mb-4">
          Контакты
        </h3>
        <ul class="space-y-3">
          <li>
            <a href="tel:+79999999999" class="text-gray-400 hover:text-gold text-sm transition-colors">
              +7 (999) 999-99-99
            </a>
          </li>
          <li>
            <a href="https://wa.me/79999999999" target="_blank" class="text-gray-400 hover:text-gold text-sm transition-colors flex items-center gap-2">
              <span>WhatsApp</span>
            </a>
          </li>
          <li>
            <a href="mailto:info@diamondprobar.ru" class="text-gray-400 hover:text-gold text-sm transition-colors">
              info@diamondprobar.ru
            </a>
          </li>
        </ul>
      </div>

      {/* Hours */}
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-widest mb-4">
          Часы работы
        </h3>
        <div class="text-gray-400 text-sm space-y-1">
          <p>Пн - Пт: 12:00 - 23:00</p>
          <p>Сб: 10:00 - 00:00</p>
          <p>Вс: 10:00 - 23:00</p>
        </div>
      </div>
    </div>

    {/* Bottom */}
    <div class="border-t border-dark-border pt-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-gray-400 text-sm">
      <p>&copy; 2024 Diamond Pro Bar. Все права защищены.</p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-gold transition-colors">Instagram</a>
        <a href="#" class="hover:text-gold transition-colors">VK</a>
